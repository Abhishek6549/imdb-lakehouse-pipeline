# Only needed if you use `./scripts/download_data.sh --source kaggle`
# Get these from https://www.kaggle.com/settings -> API -> Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# ClickHouse credentials shared by the clickhouse and loader services.
# Copy this file to .env and set your own value before running docker compose.
CLICKHOUSE_PASSWORD=change-me
